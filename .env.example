# 邮箱整理助手 - 环境变量配置模板
# 复制此文件为 .env 并填写真实值

# ==================== 邮箱账户配置 ====================

# 163工作邮箱
EMAIL_163_WORK=your_work@163.com
IMAP_USER_163_WORK=your_work@163.com
IMAP_PASS_163_WORK=your_163_work_app_password

# 163私人邮箱
EMAIL_163_PERSONAL=your_personal@163.com
IMAP_USER_163_PERSONAL=your_personal@163.com
IMAP_PASS_163_PERSONAL=your_163_personal_app_password

# Gmail邮箱
EMAIL_GMAIL=your_gmail@gmail.com
IMAP_USER_GMAIL=your_gmail@gmail.com
IMAP_PASS_GMAIL=your_gmail_app_password

# ==================== AI分类配置 ====================

# LLM配置（OpenAI兼容接口）
LLM_API_BASE=https://api.example.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=your-model-name

# ==================== 飞书通知配置 ====================

# 飞书Webhook地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 飞书Webhook密钥（可选，用于签名验证）
FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret

# ==================== 应用配置 ====================

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 调试模式
DEBUG=false
